}

</style>
""", unsafe_allow_html=True)

# --------------------------
# HEADER
# --------------------------

st.markdown("""
<div class="title">
🏛️ Smart Election Voting System
</div>
""", unsafe_allow_html=True)

st.markdown("""
<div class="card">
<h3>Secure • Transparent • Digital</h3>
<p>Face Detection | Voice Assistant | Live Results</p>
</div>
""", unsafe_allow_html=True)

# --------------------------
# TABS
# --------------------------

tab1, tab2, tab3 = st.tabs(
[
"👤 Register",
"🗳️ Vote",
"📊 Results"
]
)

# --------------------------
# REGISTER
# --------------------------

with tab1:

    st.subheader("Register Voter")

    voter_id = st.text_input("Voter ID")

    name = st.text_input("Full Name")

    if st.button("Register"):

        conn.execute(
            "INSERT OR REPLACE INTO voters VALUES(?,?)",
            (voter_id, name)
        )

        conn.commit()

        st.success("Voter Registered")

# --------------------------
# VOTE
# --------------------------

with tab2:

    st.subheader("Cast Vote")

    voter = st.text_input("Enter Voter ID")

    candidate = st.radio(
        "Choose Candidate",
        [
            "Candidate A",
            "Candidate B",
            "Candidate C"
        ]
    )

    if st.button("Submit Vote"):

        already = conn.execute(
            """
            SELECT *
            FROM votes
            WHERE voter_id=?
            """,
            (voter,)
        ).fetchone()

        if already:

            st.warning(
                "You already voted"
            )

        else:

            conn.execute(
                """
                INSERT INTO votes
                VALUES(?,?,?)
                """,
                (
                    voter,
                    candidate,
                    datetime.now().isoformat()
                )
            )

            conn.commit()

            st.balloons()

            st.success(
                "Vote Recorded Successfully"
            )

# --------------------------
# RESULTS
# --------------------------

with tab3:

    st.subheader(
        "Live Election Results"
    )

    data = pd.read_sql_query(
        """
        SELECT candidate,
        COUNT(*) AS votes
        FROM votes
        GROUP BY candidate
        """,
        conn
    )

    if len(data):

        st.bar_chart(
            data.set_index(
                "candidate"
            )
        )

        st.dataframe(data)

    else:

        st.info(
            "No votes recorded yet"
        )

# --------------------------
# SIDEBAR
# --------------------------

st.sidebar.title(
    "🔐 Admin Dashboard"
)

total_voters = conn.execute(
    "SELECT COUNT(*) FROM voters"
).fetchone()[0]

total_votes = conn.execute(
    "SELECT COUNT(*) FROM votes"
).fetchone()[0]

st.sidebar.metric(
    "Registered Voters",
    total_voters
)

st.sidebar.metric(
    "Votes Cast",
    total_votes
)

st.sidebar.success(
    "System Online"
)
