import streamlit as st
import sqlite3
import pandas as pd
from datetime import datetime

# --------------------------
# DATABASE
# --------------------------

conn = sqlite3.connect("votasecure.db", check_same_thread=False)

conn.execute("""
CREATE TABLE IF NOT EXISTS voters(
    voter_id TEXT PRIMARY KEY,
    name TEXT
)
""")

conn.execute("""
CREATE TABLE IF NOT EXISTS votes(
    voter_id TEXT,
    candidate TEXT,
    vote_time TEXT
)
""")

conn.commit()

# --------------------------
# PAGE CONFIG
# --------------------------

st.set_page_config(
    page_title="Smart Election Voting System",
    layout="wide"
)

# --------------------------
# CUSTOM CSS
# --------------------------

st.markdown("""
<style>

.stApp{
background:linear-gradient(
135deg,
#FFF9C4,
#FFF8E1,
#FFFDE7
);
}

.title{
text-align:center;
